# ===================================================
# AGI Wallet – Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control!
# ===================================================

# ---- Wallet ----------------------------------------
# The agent's Ethereum private key (controls the USDC).
# Generate one with: node -e "const {ethers}=require('ethers'); console.log(ethers.Wallet.createRandom().privateKey)"
AGENT_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ---- Network (Base Sepolia Testnet by default) ------
# Testnet RPC (free, no sign-up needed):
BASE_RPC_URL=https://sepolia.base.org
# USDC on Base Sepolia:
USDC_CONTRACT_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# For Base MAINNET, use:
# BASE_RPC_URL=https://mainnet.base.org
# USDC_CONTRACT_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# ---- API Server ------------------------------------
PORT=3000
# Secret API key used to authenticate agent requests.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AGI_API_KEY=your-secret-api-key-here

# ---- Spending Limits (USDC) ------------------------
# Maximum USDC per single charge
MAX_TX_AMOUNT=100
# Rolling daily spending cap (resets at midnight UTC)
MAX_DAILY_AMOUNT=1000
